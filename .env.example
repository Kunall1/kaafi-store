# ─── SUPABASE ─────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── RAZORPAY ─────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Only the KEY ID goes in frontend (VITE_ prefix = public)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# ─── RAZORPAY SECRET (server-side only) ───────────────────
# WARNING: Never use VITE_ prefix for this — it would expose it publicly
# This goes in Vercel environment variables only, not in this file
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ─── RESEND (email confirmations) ─────────────────────────
# Get from: https://resend.com → API Keys
# Server-side only — no VITE_ prefix
RESEND_API_KEY=re_your_resend_api_key_here

# ─── HOW TO USE ────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your real values
# 3. .env.local is in .gitignore and will never be committed
# 4. For Vercel: add these in Project → Settings → Environment Variables
